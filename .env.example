# dev-rag environment config — copy to .env and fill in as needed.
# Loaded by src/dev_rag/settings.py (pydantic-settings, case-insensitive).
# .env is gitignored — never commit real keys.
#
# Note: mcp/mcp_server.py's DEV_RAG_* vars (base URL, timeouts, optional bearer
# token) are read via plain os.getenv, NOT loaded from this file — they're set
# in .mcp.json's "env" block instead. This file only covers what settings.py reads.

# --- Anthropic (required for agent.py; everything else works without it) ---
ANTHROPIC_API_KEY=

# agent.py's synthesis model — bare model name (no "anthropic:" prefix).
# AGENT_MODEL=claude-haiku-4-5-20251001

# --- Paths (defaults are fine for local dev; relative to repo root) ---
# CHROMA_DB_PATH=./chroma_db
# SQLITE_DB_PATH=./data/dev_rag.db
# GRAPH_DB_PATH=./graph_db/knowledge_graph.json

# --- Postgres (pgvector migration — Phase 7, not yet in use) ---
# DATABASE_URL=postgresql://devrag:devrag@localhost:5432/devrag

# --- Embedding model ---
# EMBEDDING_MODEL=BAAI/bge-m3

# --- Search ---
# SEARCH_MODE=hybrid           # dense | sparse | hybrid
# RRF_K=60
# DENSE_CANDIDATES=20
# SPARSE_CANDIDATES=20

# --- Reranker (bge-reranker-v2-m3, OFF by default — ADR-012) ---
# ~15s/query at 10 candidates, ~112s/query at 50 candidates, on CPU.
# RERANKER_ENABLED=false
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_TOP_N=10
# RERANKER_CANDIDATES=50
# RERANKER_BATCH_SIZE=32
# FORCE_RERANK_CANDIDATES=10
# RERANKER_MIN_SCORE=0.5

# --- Domains ---
# VALID_DOMAINS=["devops", "python", "ai"]
